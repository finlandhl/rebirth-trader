# Binance Futures API Credentials
BINANCE_API_KEY=your_api_key_here
BINANCE_API_SECRET=your_api_secret_here

# Stream Configuration
STREAM_INTERVAL=1m
STREAM_LIMIT=100

# Kline/Candlestick Configuration
# Single interval (backward compatible):
# KLINE_INTERVAL=1m

# Multiple intervals (comma-separated):
# Supports: 1m, 3m, 5m, 15m, 30m, 1h, 2h, 4h, 6h, 8h, 12h, 1d, 3d, 1w, 1M
KLINE_INTERVALS=1m,5m,15m,1h,4h,1d

# Enable/Disable Stream Types
ENABLE_KLINES=true
ENABLE_ORDERBOOK=true
